{
  "id": "cove.community.scrapers.ytdlp",
  "name": "yt-dlp Scraper",
  "version": "1.0.0",
  "description": "Extracts scene metadata with yt-dlp.",
  "author": "Cove Team",
  "url": "https://github.com/yourcove/communityscrapers",
  "minCoveVersion": "0.0.28",
  "entryDll": "YtDlpScraper.dll",
  "categories": [
    "scraper",
    "metadata",
    "integration"
  ],
  "permissions": {
    "network": [
      "*"
    ],
    "process": [
      "yt-dlp"
    ]
  },
  "externalDependencies": [
    {
      "id": "yt-dlp",
      "name": "yt-dlp",
      "description": "Command line metadata extractor used for generic video sites.",
      "required": true,
      "configurationKeys": [
        "ytDlpPath"
      ]
    }
  ],
  "settings": [
    {
      "name": "ytDlpPath",
      "displayName": "yt-dlp executable path",
      "type": "STRING",
      "description": "Path to yt-dlp, or yt-dlp when it is available on PATH.",
      "extensionIds": [
        "cove.community.scrapers.ytdlp"
      ]
    }
  ]
}
