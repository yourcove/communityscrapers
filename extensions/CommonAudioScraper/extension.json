{
  "id": "cove.community.scrapers.common-audio",
  "name": "Common Audio Scraper",
  "version": "1.0.0",
  "description": "Extracts audio metadata from common hosted-audio pages such as Soundgasm and Whyp.",
  "author": "Cove Team",
  "url": "https://github.com/yourcove/communityscrapers",
  "minCoveVersion": "0.0.32",
  "entryDll": "CommonAudioScraper.dll",
  "categories": [
    "scraper",
    "metadata",
    "audio"
  ],
  "permissions": {
    "network": [
      "soundgasm.net",
      "*.soundgasm.net",
      "whyp.it",
      "*.whyp.it"
    ]
  }
}
